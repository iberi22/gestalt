# Gestalt SuperAgent Environment Variables
# Copy this file to .env and fill in your values

# ============ LLM API Keys ============
# Required for AI capabilities (set ONE OR MORE)

# Gemini (Google AI Studio): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# MiniMax: https://platform.minimax.chat/
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-minimax-group-id-here

# ============ Search APIs ============
BRAVE_API_KEY=your-brave-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# ============ Gestalt MCP Server ============
GESTALT_MCP_URL=http://127.0.0.1:3000

# ============ Database (Optional) ============
# SurrealDB defaults to embedded mode (mem)
# For remote connection:
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root

# ============ Legacy (Deprecated) ============
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password
